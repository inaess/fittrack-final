{% extends 'base.html.twig' %}
{% block title %}Catégories{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-tag me-2" style="color:#2ecc71;"></i>Catégories</h1>
    <a href="{{ path('app_categorie_new') }}" class="btn btn-sport">
        <i class="bi bi-plus-circle me-2"></i>Nouvelle catégorie
    </a>
</div>

{% if categories|length > 0 %}
<div class="row">
    {% for categorie in categories %}
    <div class="col-md-4 mb-4">
        <div class="card card-modern h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div style="width:48px;height:48px;border-radius:50%;background:{{ categorie.couleur }};flex-shrink:0;"></div>
                <div>
                    <h5 class="mb-0 fw-bold">{{ categorie.nom }}</h5>
                    <small class="text-muted">{{ categorie.couleur }}</small>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pb-3">
                <div class="d-flex gap-2">
                    <a href="{{ path('app_categorie_show', {'id': categorie.id}) }}" class="btn btn-sm btn-outline-success">
                        <i class="bi bi-eye"></i> Voir
                    </a>
                    <a href="{{ path('app_categorie_edit', {'id': categorie.id}) }}" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-pencil"></i> Modifier
                    </a>
                </div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="card card-modern text-center py-5">
    <div class="card-body">
        <i class="bi bi-tag" style="font-size:4rem;color:#2ecc71;"></i>
        <h3 class="mt-3">Aucune catégorie</h3>
        <a href="{{ path('app_categorie_new') }}" class="btn btn-sport mt-2">
            <i class="bi bi-plus-circle"></i> Créer une catégorie
        </a>
    </div>
</div>
{% endif %}
{% endblock %}
