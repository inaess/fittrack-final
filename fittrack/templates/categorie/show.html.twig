{% extends 'base.html.twig' %}
{% block title %}{{ categorie.nom }}{% endblock %}
{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <span style="display:inline-block;width:32px;height:32px;border-radius:8px;background:{{ categorie.couleur }};vertical-align:middle;margin-right:10px;"></span>
            {{ categorie.nom }}
        </h1>
        <div class="d-flex gap-2">
            <a href="{{ path('app_categorie_edit', {'id': categorie.id}) }}" class="btn btn-sport">
                <i class="bi bi-pencil"></i> Modifier
            </a>
            <a href="{{ path('app_categorie_index') }}" class="btn btn-outline-secondary" style="border-radius:30px;">
                <i class="bi bi-arrow-left"></i> Retour
            </a>
        </div>
    </div>

    {% if categorie.programmes|length > 0 %}
        <h5 class="mb-3 text-muted">
            <i class="bi bi-journal-text me-2"></i>
            {{ categorie.programmes|length }} programme(s) dans cette catégorie
        </h5>
        <div class="row">
            {% for programme in categorie.programmes %}
                <div class="col-md-4 mb-4">
                    <div class="card card-modern h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 class="fw-bold mb-0">
                                    <i class="bi bi-trophy me-1" style="color:#f39c12;"></i>
                                    {{ programme.nom }}
                                </h5>
                                {% set niveauLower = programme.niveau|lower %}
                                {% if 'interm' in niveauLower %}
                                    <span style="background:#f39c12;color:white;padding:4px 10px;border-radius:20px;font-size:12px;font-weight:500;">{{ programme.niveau }}</span>
                                {% elseif 'avan' in niveauLower %}
                                    <span style="background:#e74c3c;color:white;padding:4px 10px;border-radius:20px;font-size:12px;font-weight:500;">{{ programme.niveau }}</span>
                                {% else %}
                                    <span style="background:#2ecc71;color:white;padding:4px 10px;border-radius:20px;font-size:12px;font-weight:500;">{{ programme.niveau }}</span>
                                {% endif %}
                            </div>
                            <p class="text-muted" style="font-size:14px;">
                                {{ programme.description|length > 100 ? programme.description|slice(0,100) ~ '...' : programme.description }}
                            </p>
                            {% if programme.seances|length > 0 %}
                                <span class="badge bg-success bg-opacity-25 text-success">
                        <i class="bi bi-calendar-check"></i> {{ programme.seances|length }} séance(s)
                    </span>
                            {% endif %}
                        </div>
                        <div class="card-footer bg-transparent border-0 pb-3">
                            <a href="{{ path('app_programme_show', {'id': programme.id}) }}" class="btn btn-sm btn-outline-success">
                                <i class="bi bi-eye"></i> Voir le programme
                            </a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="card card-modern text-center py-5">
            <div class="card-body">
                <i class="bi bi-journal-x" style="font-size:4rem;color:#2ecc71;"></i>
                <h3 class="mt-3">Aucun programme dans cette catégorie</h3>
                <a href="{{ path('app_programme_new') }}" class="btn btn-sport mt-2">
                    <i class="bi bi-plus-circle"></i> Créer un programme
                </a>
            </div>
        </div>
    {% endif %}

    <div class="mt-4">
        {{ include('categorie/_delete_form.html.twig') }}
    </div>
{% endblock %}
