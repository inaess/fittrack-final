{% extends 'base.html.twig' %}

{% block title %}Mes programmes{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="bi bi-journal-text me-2" style="color: #2ecc71;"></i>
            Mes programmes
        </h1>
        <a href="{{ path('app_programme_new') }}" class="btn btn-sport">
            <i class="bi bi-plus-circle me-2"></i>Nouveau programme
        </a>
    </div>

    {% if programmes|length > 0 %}
        <div class="row">
            {% for programme in programmes %}
                <div class="col-md-4 mb-4">
                    <div class="card card-modern h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 class="card-title mb-0 fw-bold">
                                    <i class="bi bi-trophy me-1" style="color: #f39c12;"></i>
                                    {{ programme.nom }}
                                </h5>
                                {% set niveauClass = 'debutant' %}
                                {% if programme.niveau|lower == 'intermediaire' or programme.niveau|lower == 'intermédiaire' %}
                                    {% set niveauClass = 'intermediaire' %}
                                {% elseif programme.niveau|lower == 'avance' or programme.niveau|lower == 'avancé' %}
                                    {% set niveauClass = 'avance' %}
                                {% endif %}
                                <span class="badge-{{ niveauClass }}">
                        {{ programme.niveau|default('Débutant') }}
                    </span>
                            </div>

                            <p class="card-text text-muted">
                                {{ programme.description|length > 120 ? programme.description|slice(0, 120) ~ '...' : programme.description }}
                            </p>

                            <div class="mt-3">
                                {% if programme.categorie %}
                                    <span class="badge bg-info bg-opacity-25 text-dark">
                            <i class="bi bi-tag"></i> {{ programme.categorie.nom }}
                        </span>
                                {% endif %}
                                {% if programme.seances|length > 0 %}
                                    <span class="badge bg-success bg-opacity-25 text-success ms-2">
                            <i class="bi bi-calendar-check"></i> {{ programme.seances|length }} séance(s)
                        </span>
                                {% endif %}
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-0 pb-3">
                            <div class="d-flex gap-2">
                                <a href="{{ path('app_programme_show', {'id': programme.id}) }}" class="btn btn-sm btn-outline-success">
                                    <i class="bi bi-eye"></i> Voir
                                </a>
                                <a href="{{ path('app_programme_edit', {'id': programme.id}) }}" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i> Modifier
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="card card-modern text-center py-5">
            <div class="card-body">
                <i class="bi bi-emoji-smile" style="font-size: 4rem; color: #2ecc71;"></i>
                <h3 class="mt-3">Aucun programme pour le moment</h3>
                <p class="text-muted">Commencez par créer votre premier programme d'entraînement !</p>
                <a href="{{ path('app_programme_new') }}" class="btn btn-sport mt-2">
                    <i class="bi bi-plus-circle"></i> Créer un programme
                </a>
            </div>
        </div>
    {% endif %}
{% endblock %}
