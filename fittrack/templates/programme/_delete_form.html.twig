<form method="post" action="{{ path('app_programme_delete', {'id': programme.id}) }}"
      onsubmit="return confirm('Supprimer ce programme ?')">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ programme.id) }}">
    <button type="submit" class="btn btn-danger" style="border-radius:30px;">
        <i class="bi bi-trash me-1"></i> Supprimer
    </button>
</form>
