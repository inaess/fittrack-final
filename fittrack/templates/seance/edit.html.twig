{% extends 'base.html.twig' %}
{% block title %}Modifier la séance{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-pencil me-2" style="color:#2ecc71;"></i>Modifier la séance</h1>
    <a href="{{ path('app_seance_index') }}" class="btn btn-outline-secondary" style="border-radius:30px;">
        <i class="bi bi-arrow-left"></i> Retour
    </a>
</div>
<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card card-modern p-4">
            {{ include('seance/_form.html.twig', {'button_label': 'Enregistrer'}) }}
            <div class="mt-3 border-top pt-3">
                {{ include('seance/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
