<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}FitTrack{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        :root {
            --sport-green: #2ecc71;
            --sport-green-dark: #27ae60;
            --dark-bg: #1e272e;
        }

        body { background-color: #f0f2f5; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .navbar-brand { font-weight: 700; font-size: 1.4rem; letter-spacing: 1px; }

        .sidebar {
            background: linear-gradient(180deg, #1e272e 0%, #2c3e50 100%);
            min-height: calc(100vh - 56px);
            box-shadow: 2px 0 10px rgba(0,0,0,0.1);
        }



        .sidebar .nav-link {
            color: rgba(255,255,255,0.85);
            border-radius: 10px;
            margin: 5px 12px;
            padding: 12px 15px;
            transition: all 0.3s ease;
            font-weight: 500;
        }

        .sidebar .nav-link i {
            margin-right: 12px;
            width: 24px;
            font-size: 1.2rem;
        }

        .sidebar .nav-link:hover {
            background: var(--sport-green);
            color: white;
            transform: translateX(5px);
        }

        .sidebar .nav-link.active {
            background: var(--sport-green);
            color: white;
        }

        /* Contenu principal */
        .main-content {
            padding: 2rem;
            background: #f0f2f5;
            min-height: calc(100vh - 56px);
        }

        /* Cartes modernes */
        .card-modern {
            border: none;
            border-radius: 16px;
            transition: transform 0.3s, box-shadow 0.3s;
            background: white;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        }

        .card-modern:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 24px rgba(0,0,0,0.12);
        }


        .badge-debutant { background: #2ecc71; color: white; padding: 5px 12px; border-radius: 20px; font-weight: 500; }
        .badge-intermediaire { background: #f39c12; color: white; padding: 5px 12px; border-radius: 20px; font-weight: 500; }
        .badge-avance { background: #e74c3c; color: white; padding: 5px 12px; border-radius: 20px; font-weight: 500; }

        /* Bouton sport */
        .btn-sport {
            background: var(--sport-green);
            border: none;
            border-radius: 30px;
            padding: 8px 24px;
            font-weight: 600;
            transition: all 0.3s;
        }
        .btn-sport:hover {
            background: var(--sport-green-dark);
            transform: scale(1.02);
        }

        /* Tableaux améliorés */
        .table-modern {
            background: white;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        }
        .table-modern thead {
            background: var(--dark-bg);
            color: white;
        }
        .table-modern th {
            padding: 14px 16px;
            font-weight: 600;
        }
        .table-modern td {
            padding: 12px 16px;
            vertical-align: middle;
        }
    </style>
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body>
<nav class="navbar navbar-dark px-3 shadow-sm " style="background: #1e272e;">
    <a class="navbar-brand" href="{{ path('app_programme_index') }}">💪 FitTrack</a>
    <div class="d-flex align-items-center gap-3">
        {% if app.user %}
            <span class="text-white-50 small">
                <i class="bi bi-person-circle"></i> {{ app.user.userIdentifier }}
            </span>
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('admin') }}" class="btn btn-sm btn-outline-warning">
                    <i class="bi bi-gear"></i> Admin
                </a>
            {% endif %}
            <a href="{{ logout_path() }}" class="btn btn-sm btn-outline-light">
                <i class="bi bi-box-arrow-right"></i> Déconnexion
            </a>
        {% endif %}
    </div>
</nav>

<div class="container-fluid">
    <div class="row">
        {% if app.user %}
        <nav class="col-md-2 sidebar py-4">
            <div class="text-center mb-4 pb-2">
                <div style="font-size: 2.8rem;">💪</div>
                <h5 class="text-white mb-0 mt-2">FitTrack</h5>
                <small class="text-white-50">Suivi sportif</small>
            </div>
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link {% if app.request.get('_route') starts with 'app_programme' %}active{% endif %}" href="{{ path('app_programme_index') }}">
                        <i class="bi bi-journal-text"></i> Programmes
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {% if app.request.get('_route') starts with 'app_seance' %}active{% endif %}" href="{{ path('app_seance_index') }}">
                        <i class="bi bi-calendar-check"></i> Séances
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {% if app.request.get('_route') starts with 'app_exercice' %}active{% endif %}" href="{{ path('app_exercice_index') }}">
                        <i class="bi bi-activity"></i> Exercices
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {% if app.request.get('_route') starts with 'app_categorie' %}active{% endif %}" href="{{ path('app_categorie_index') }}">
                        <i class="bi bi-tag"></i> Catégories
                    </a>
                </li>
            </ul>
        </nav>
        <main class="col-md-10 main-content">
            {% else %}
            <main class="col-12 main-content">
                {% endif %}
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 mb-3" role="alert">
                        <i class="bi bi-check-circle-fill"></i>
                        <span>{{ message }}</span>
                        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                    <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2 mb-3" role="alert">
                        <i class="bi bi-x-circle-fill"></i>
                        <span>{{ message }}</span>
                        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
                {% block body %}{% endblock %}
            </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
