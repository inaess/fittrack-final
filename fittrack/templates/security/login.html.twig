{% extends 'base.html.twig' %}

{% block title %}Connexion — FitTrack{% endblock %}

{% block body %}
<div class="min-vh-100 d-flex align-items-center justify-content-center"
     style="margin: -2rem; background: linear-gradient(135deg, #1e272e, #2c3e50);">
    <div class="card shadow-lg" style="width: 100%; max-width: 420px; border-radius: 24px; border: none;">
        <div class="card-body p-5">
            <div class="text-center mb-4">
                <div style="font-size: 3rem;">💪</div>
                <h1 class="h3 fw-bold" style="color: #1e272e;">FitTrack</h1>
                <p class="text-muted small">Connectez-vous à votre espace sportif</p>
            </div>

            {% if error %}
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <form method="post">
                <div class="mb-3">
                    <label for="inputEmail" class="form-label fw-semibold">Email</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0">
                            <i class="bi bi-envelope" style="color: #2ecc71;"></i>
                        </span>
                        <input type="email" value="{{ last_username }}" name="email" id="inputEmail"
                               class="form-control border-0 bg-light" autocomplete="email" required autofocus
                               placeholder="votre@email.com">
                    </div>
                </div>

                <div class="mb-3">
                    <label for="inputPassword" class="form-label fw-semibold">Mot de passe</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0">
                            <i class="bi bi-lock" style="color: #2ecc71;"></i>
                        </span>
                        <input type="password" name="password" id="inputPassword"
                               class="form-control border-0 bg-light" autocomplete="current-password" required
                               placeholder="••••••••">
                    </div>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="mb-4">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="_remember_me" id="rememberMe">
                        <label class="form-check-label text-muted small" for="rememberMe">
                            Se souvenir de moi
                        </label>
                    </div>
                </div>

                <button class="btn w-100 py-2 fw-semibold" type="submit" style="background: #2ecc71; color: white; border-radius: 40px;">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Se connecter
                </button>

                <hr class="my-3">

                <p class="text-center text-muted small mb-0">
                    Pas encore de compte ?
                    <a href="{{ path('app_register') }}" style="color: #2ecc71; text-decoration: none; font-weight: 600;">S'inscrire</a>
                </p>
            </form>
        </div>
    </div>
</div>
{% endblock %}