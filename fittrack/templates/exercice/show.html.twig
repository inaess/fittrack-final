{% extends 'base.html.twig' %}
{% block title %}{{ exercice.nom }}{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-activity me-2" style="color:#2ecc71;"></i>{{ exercice.nom }}</h1>
    <div class="d-flex gap-2">
        <a href="{{ path('app_exercice_edit', {'id': exercice.id}) }}" class="btn btn-sport">
            <i class="bi bi-pencil"></i> Modifier
        </a>
        <a href="{{ path('app_exercice_index') }}" class="btn btn-outline-secondary" style="border-radius:30px;">
            <i class="bi bi-arrow-left"></i> Retour
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card card-modern p-4">
            <h5 class="fw-bold mb-3">Informations</h5>
            <p class="text-muted mb-1" style="font-size:13px;">Nom</p>
            <p class="fw-bold mb-3">{{ exercice.nom }}</p>
            <p class="text-muted mb-1" style="font-size:13px;">Description</p>
            <p class="mb-4">{{ exercice.description ?? 'Aucune description' }}</p>
            <div class="border-top pt-3">
                {{ include('exercice/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card card-modern p-4 text-center">
            <h5 class="fw-bold mb-3">Image</h5>
            {% if exercice.imageFile %}
                <img src="{{ asset('uploads/exercices/' ~ exercice.imageFile) }}"
                     alt="{{ exercice.nom }}"
                     style="max-width:100%;border-radius:12px;">
            {% else %}
                <div class="py-5 text-muted">
                    <i class="bi bi-image" style="font-size:3rem;"></i>
                    <p class="mt-2">Aucune image</p>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
