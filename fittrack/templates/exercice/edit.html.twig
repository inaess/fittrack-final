{% extends 'base.html.twig' %}
{% block title %}Modifier {{ exercice.nom }}{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-pencil me-2" style="color:#2ecc71;"></i>Modifier l'exercice</h1>
    <a href="{{ path('app_exercice_index') }}" class="btn btn-outline-secondary" style="border-radius:30px;">
        <i class="bi bi-arrow-left"></i> Retour
    </a>
</div>
<div class="row">
    <div class="col-md-7">
        <div class="card card-modern p-4">
            {{ include('exercice/_form.html.twig', {'button_label': 'Enregistrer'}) }}
        </div>
    </div>
    <div class="col-md-5">
        <div class="card card-modern p-4 text-center">
            <h6 class="fw-bold mb-3">Image actuelle</h6>
            {% if exercice.imageFile %}
                <img src="{{ asset('uploads/exercices/' ~ exercice.imageFile) }}"
                     alt="{{ exercice.nom }}"
                     style="max-width:100%;border-radius:12px;">
            {% else %}
                <div class="py-4 text-muted">
                    <i class="bi bi-image" style="font-size:3rem;"></i>
                    <p class="mt-2">Aucune image</p>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
