{% extends 'base.html.twig' %}
{% block title %}Exercices{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-activity me-2" style="color:#2ecc71;"></i>Exercices</h1>
    <a href="{{ path('app_exercice_new') }}" class="btn btn-sport">
        <i class="bi bi-plus-circle me-2"></i>Nouvel exercice
    </a>
</div>

{% if exercices|length > 0 %}
<div class="row">
    {% for exercice in exercices %}
    <div class="col-md-4 mb-4">
        <div class="card card-modern h-100">
            {% if exercice.imageFile %}
                <img src="{{ asset('uploads/exercices/' ~ exercice.imageFile) }}"
                     alt="{{ exercice.nom }}"
                     style="width:100%;max-height:220px;object-fit:contain;border-radius:16px 16px 0 0;background:#f8f9fa;padding:10px;">
            {% else %}
                <div style="width:100%;height:120px;background:#f0f2f5;border-radius:16px 16px 0 0;display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-image text-muted" style="font-size:2.5rem;"></i>
                </div>
            {% endif %}
            <div class="card-body">
                <h5 class="fw-bold mb-2">{{ exercice.nom }}</h5>
                <p class="text-muted" style="font-size:14px;">
                    {{ exercice.description|length > 80 ? exercice.description|slice(0,80) ~ '...' : exercice.description }}
                </p>
            </div>
            <div class="card-footer bg-transparent border-0 pb-3">
                <div class="d-flex gap-2">
                    <a href="{{ path('app_exercice_show', {'id': exercice.id}) }}" class="btn btn-sm btn-outline-success">
                        <i class="bi bi-eye"></i> Voir
                    </a>
                    <a href="{{ path('app_exercice_edit', {'id': exercice.id}) }}" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-pencil"></i> Modifier
                    </a>
                </div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="card card-modern text-center py-5">
    <div class="card-body">
        <i class="bi bi-activity" style="font-size:4rem;color:#2ecc71;"></i>
        <h3 class="mt-3">Aucun exercice</h3>
        <a href="{{ path('app_exercice_new') }}" class="btn btn-sport mt-2">
            <i class="bi bi-plus-circle"></i> Créer un exercice
        </a>
    </div>
</div>
{% endif %}
{% endblock %}
