{% extends 'base.html.twig' %}

{% block title %}Inscription — FitTrack{% endblock %}

{% block body %}
<div class="min-vh-100 d-flex align-items-center justify-content-center"
     style="margin: -2rem; background: linear-gradient(135deg, #1e272e, #2c3e50);">
    <div class="card shadow-lg" style="width: 100%; max-width: 420px; border-radius: 24px; border: none;">
        <div class="card-body p-5">
            <div class="text-center mb-4">
                <div style="font-size: 3rem;">💪</div>
                <h1 class="h3 fw-bold" style="color: #1e272e;">Créer un compte</h1>
                <p class="text-muted small">Rejoignez FitTrack et commencez votre transformation 💪</p>
            </div>

            {{ form_errors(registrationForm) }}

            {{ form_start(registrationForm) }}
                <div class="mb-3">
                    <label class="form-label fw-semibold">Email</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0">
                            <i class="bi bi-envelope" style="color: #2ecc71;"></i>
                        </span>
                        {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control border-0 bg-light', 'placeholder': 'votre@email.com'}}) }}
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Mot de passe</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0">
                            <i class="bi bi-lock" style="color: #2ecc71;"></i>
                        </span>
                        {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-control border-0 bg-light', 'placeholder': '••••••••'}}) }}
                    </div>
                </div>

                <div class="mb-4">
                    <div class="form-check">
                        {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'form-check-input'}}) }}
                        <label class="form-check-label text-muted small">
                            J'accepte les conditions d'utilisation
                        </label>
                    </div>
                </div>

                <button class="btn w-100 py-2 fw-semibold" type="submit" style="background: #2ecc71; color: white; border-radius: 40px;">
                    <i class="bi bi-person-plus me-2"></i>Créer mon compte
                </button>

                <hr class="my-3">

                <p class="text-center text-muted small mb-0">
                    Déjà un compte ?
                    <a href="{{ path('app_login') }}" style="color: #2ecc71; text-decoration: none; font-weight: 600;">Se connecter</a>
                </p>
            {{ form_end(registrationForm) }}
        </div>
    </div>
</div>
{% endblock %}